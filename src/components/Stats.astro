---
const stats = [
  { value: '+3.200', label: 'pacientes tratados', tone: 'text-cyan' },
  { value: '12', label: 'años de experiencia clínica', tone: 'text-white' },
  { value: '94%', label: 'retorno funcional satisfactorio', tone: 'text-magenta' },
  { value: '8', label: 'especialistas en el equipo', tone: 'text-white' },
];
---

<section class="px-4 py-20 md:px-8 md:py-28">
  <div class="section-shell overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/[0.03] px-6 py-10 md:px-10 md:py-14">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-end">
      <div>
        <span class="section-label"><span class="eyebrow-dot"></span>Impacto</span>
        <h2 class="display-title mt-6 max-w-xl text-4xl text-white sm:text-5xl md:text-6xl">Resultados que se sienten en el cuerpo y se sostienen en el tiempo.</h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {stats.map((stat, index) => (
          <article class={`surface-panel rounded-[2rem] p-6 md:p-8 ${index % 2 === 1 ? 'sm:translate-y-8' : ''}`}>
            <p class={`font-heading text-5xl font-bold tracking-[-0.08em] md:text-6xl ${stat.tone}`}>{stat.value}</p>
            <p class="mt-3 max-w-[14rem] text-sm leading-6 tracking-[0.16em] text-white/62 uppercase">{stat.label}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
