---
const team = [
  {
    name: 'Valentina Rojas',
    specialty: 'Fisioterapia deportiva',
    bio: 'Especialista en readaptación al esfuerzo y control de carga. Acompaña procesos de retorno al deporte y recuperación funcional.',
    image: '/img2.webp',
    alt: 'Profesional acompañando ejercicio terapéutico de equilibrio',
  },
  {
    name: 'Nicolás Mejía',
    specialty: 'Terapia manual y dolor',
    bio: 'Integra terapia manual, educación en dolor y ejercicio terapéutico para pacientes con cuadros persistentes y complejos.',
    image: '/img3.webp',
    alt: 'Profesional de fisioterapia sosteniendo un modelo anatómico de pelvis',
  },
  {
    name: 'Camila Torres',
    specialty: 'Neurorehabilitación',
    bio: 'Enfocada en equilibrio, marcha y control motor para mejorar independencia funcional con objetivos concretos y progresivos.',
    image: '/img4.webp',
    alt: 'Profesional de fisioterapia frente al logo de Fisio Motora',
  },
];
---

<section id="equipo" class="px-4 py-18 md:px-8 md:py-24">
  <div class="section-shell">
    <div class="mb-8 max-w-2xl lg:ml-8 xl:ml-14">
      <span class="section-label"><span class="eyebrow-dot"></span>Equipo</span>
      <h2 class="display-title mt-5 max-w-xl text-4xl text-white sm:text-4xl md:text-6xl">
        Profesionales que combinan <span class="gradient-text">criterio clínico</span> y cercanía.
      </h2>
      <p class="mt-5 max-w-lg text-base leading-8 text-white/72 md:text-lg">
        Un equipo preparado para escuchar tu caso, explicarte cada paso y acompañarte con claridad durante todo el proceso.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {team.map((member) => (
        <article class="flex flex-col rounded-[1.4rem] bg-surface p-4 shadow-[0_14px_36px_rgba(10,10,10,0.04)] md:p-5">
          <div class="relative mb-4 aspect-[1.18] overflow-hidden rounded-[1.15rem] bg-white">
            <img
              src={member.image}
              alt={member.alt}
              class="h-full w-full object-cover object-center"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0)_55%,rgba(10,10,10,0.10)_100%)]"></div>
          </div>
          <p class="font-heading text-lg font-semibold text-white">{member.name}</p>
          <p class="mt-2 text-xs tracking-[0.18em] text-cyan uppercase">{member.specialty}</p>
          <p class="mt-2.5 text-sm leading-6 text-white/70">{member.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>
