---
const testimonials = [
  {
    quote:
      'Llegué por dolor lumbar de meses y salí entendiendo por qué me pasaba. No solo bajó el dolor: volví a entrenar con seguridad y mejores hábitos.',
    name: 'Laura M.',
    context: 'Paciente de readaptación funcional',
  },
  {
    quote:
      'Después de un esguince de tobillo pensé que iba a tardar mucho más. El plan fue claro, exigente y muy humano. Recuperé estabilidad y confianza.',
    name: 'Andrés P.',
    context: 'Paciente de rehabilitación deportiva',
  },
  {
    quote:
      'Sentí una diferencia enorme en el seguimiento. Siempre sabíamos qué estábamos haciendo, por qué y cuál era el siguiente paso. Eso da mucha tranquilidad.',
    name: 'Mariana R.',
    context: 'Paciente de fisioterapia manual',
  },
];
---

<section class="px-4 py-20 md:px-8 md:py-28">
  <div class="section-shell">
    <div class="mb-10 max-w-2xl">
      <span class="section-label"><span class="eyebrow-dot"></span>Testimonios</span>
      <h2 class="display-title mt-6 text-4xl text-white sm:text-5xl md:text-6xl">Personas reales, procesos reales, recuperaciones que vuelven a ponerse en marcha.</h2>
    </div>

    <div class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
      <article class="surface-panel rounded-[2.2rem] p-7 md:p-10 lg:min-h-[25rem]">
        <p class="font-heading text-6xl leading-none text-cyan">“</p>
        <p class="mt-4 max-w-2xl text-xl leading-9 text-white/84 md:text-2xl">{testimonials[0].quote}</p>
        <div class="mt-8">
          <p class="font-heading text-2xl font-semibold text-white">{testimonials[0].name}</p>
          <p class="mt-1 text-sm tracking-[0.18em] text-white/56 uppercase">{testimonials[0].context}</p>
        </div>
      </article>

      <div class="grid gap-5">
        {testimonials.slice(1).map((testimonial, index) => (
          <article class={`surface-panel rounded-[2rem] p-6 md:p-8 ${index === 0 ? 'lg:translate-x-8' : ''}`}>
            <p class="text-lg leading-8 text-white/80">“{testimonial.quote}”</p>
            <div class="mt-6">
              <p class="font-heading text-xl font-semibold text-white">{testimonial.name}</p>
              <p class="mt-1 text-xs tracking-[0.18em] text-white/56 uppercase">{testimonial.context}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
